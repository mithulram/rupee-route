{
  "name": "@rupeeroute/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "sh -c 'set -a && . ./.env && set +a && exec nest start --watch'",
    "start": "sh -c 'set -a && . ./.env && set +a && exec node dist/main.js'",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.11",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/swagger": "^11.0.6",
    "@nestjs/throttler": "^6.4.0",
    "@rupeeroute/api-contracts": "workspace:*",
    "@rupeeroute/config": "workspace:*",
    "@rupeeroute/domain": "workspace:*",
    "@rupeeroute/observability": "workspace:*",
    "@rupeeroute/provider-sdk": "workspace:*",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.41.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.0.11",
    "@swc/core": "^1.15.41",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.8"
  }
}
