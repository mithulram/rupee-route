{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "paths": {
      "@rupeeroute/worker/sandbox-worker": ["../worker/dist/sandbox-worker"]
    },
    "outDir": "dist",
    "rootDir": "src",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "noImplicitAny": true
  },
  "include": ["src/**/*.ts"]
}
