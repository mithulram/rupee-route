REDIS_URL=redis://localhost:6379
NODE_ENV=development
LOG_LEVEL=info
LIVE_TRANSFERS_ENABLED=false
SANDBOX_FORCE_KYC_APPROVED=true
API_PORT=3001
JWT_SECRET=local-dev-jwt-secret-min-16-chars
