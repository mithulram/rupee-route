{
  "name": "@rupeeroute/observability",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./correlation.middleware": {
      "types": "./dist/correlation.middleware.d.ts",
      "default": "./dist/correlation.middleware.js"
    },
    "./admin-audit": {
      "types": "./dist/admin-audit.d.ts",
      "default": "./dist/admin-audit.js"
    },
    "./monitoring": {
      "types": "./dist/monitoring.d.ts",
      "default": "./dist/monitoring.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "vitest": "^3.0.8"
  }
}
