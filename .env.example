# Shared infrastructure
DATABASE_URL=postgresql://rupeeroute:rupeeroute@localhost:5432/rupeeroute?schema=public
REDIS_URL=redis://localhost:6379

# Application
NODE_ENV=development
LOG_LEVEL=info

# Feature flags (sandbox defaults)
LIVE_TRANSFERS_ENABLED=false

# API / Worker
API_PORT=3001
WORKER_PORT=3002
JWT_SECRET=change-me-in-production-use-long-random-string
WEBHOOK_SIGNING_SECRET=sandbox-webhook-secret-change-me

# Web / Admin (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SANDBOX_BANNER=true

# Mobile (Expo)
EXPO_PUBLIC_API_URL=http://localhost:3001
